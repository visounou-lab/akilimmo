generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OWNER
  TENANT
}

enum Country {
  BENIN
  COTE_D_IVOIRE
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  RENTED
  OFF_MARKET
}

enum ContractStatus {
  PENDING
  ACTIVE
  TERMINATED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum NotificationCategory {
  BOOKING
  PAYMENT
  DOCUMENT
  ALERT
  MESSAGE
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           Role           @default(TENANT)
  phone          String?
  country        Country?
  city           String?
  isVerified     Boolean        @default(false)
  verifyToken    String?        @unique
  verifyExpires  DateTime?
  resetToken     String?        @unique
  resetExpires   DateTime?
  status         String         @default("pending")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  sessions       Session[]
  properties          Property[]     @relation("OwnerProperties")
  submittedProperties Property[]     @relation("SubmittedProperties")
  contracts           Contract[]     @relation("TenantContracts")
  ownedContracts      Contract[]     @relation("OwnerContracts")
  payments            Payment[]
  notifications       Notification[]
  documentRequests    DocumentRequest[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String
  description   String
  country       Country
  city          String
  address       String
  price         Decimal
  status        PropertyStatus  @default(AVAILABLE)
  bedrooms      Int
  bathrooms     Int
  imageUrl      String?
  videoUrl      String?
  ownerId       String
  owner         User            @relation("OwnerProperties", fields: [ownerId], references: [id])
  submittedBy   String?
  submitter     User?           @relation("SubmittedProperties", fields: [submittedBy], references: [id])
  propertyType  String?
  publishStatus String          @default("published")
  adminNote     String?
  contracts        Contract[]
  notifications    Notification[]
  images           PropertyImage[]
  documentRequests DocumentRequest[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  publicId   String?
  alt        String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([propertyId, isPrimary])
}

model Contract {
  id         String         @id @default(cuid())
  property   Property       @relation(fields: [propertyId], references: [id])
  propertyId String
  tenant     User           @relation("TenantContracts", fields: [tenantId], references: [id])
  tenantId   String
  owner      User           @relation("OwnerContracts", fields: [ownerId], references: [id])
  ownerId    String
  startDate  DateTime
  endDate    DateTime
  rentAmount Decimal
  status     ContractStatus @default(PENDING)
  pdfUrl     String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  payments   Payment[]
}

model Payment {
  id                  String        @id @default(cuid())
  contract            Contract      @relation(fields: [contractId], references: [id])
  contractId          String
  payer               User          @relation(fields: [payerId], references: [id])
  payerId             String
  amount              Decimal
  status              PaymentStatus @default(PENDING)
  dueDate             DateTime
  paidAt              DateTime?

  // Wave payment fields
  paymentMethod       String?       // "wave", "orange_money", "bank_transfer"
  waveTransactionId   String?       @unique // Wave transaction ID
  waveReference       String?       // Wave reference/receipt
  waveStatus          String?       // wave_completed, wave_failed, wave_pending

  // Fees & calculations
  grossAmount         Decimal?      // Montant brut (avant frais AKIL IMMO)
  akilimmoFeeAmount   Decimal?      // Commission AKIL IMMO (6%)
  netAmount           Decimal?      // Montant net propriétaire

  // Metadata
  payerPhone          String?       // Store phone for Wave/Orange Money
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Notification {
  id         String               @id @default(cuid())
  user       User                 @relation(fields: [userId], references: [id])
  userId     String
  title      String
  body       String
  category   NotificationCategory
  actionUrl  String?
  isRead     Boolean              @default(false)
  property   Property?            @relation(fields: [propertyId], references: [id])
  propertyId String?
  createdAt  DateTime             @default(now())
}

model DocumentRequest {
  id          String    @id @default(cuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type        String
  status      String    @default("pending")
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  message     String?
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  @@index([ownerId])
  @@index([status])
}
