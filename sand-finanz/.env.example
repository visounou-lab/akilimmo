# SAND FINANZ GRUPPE — environment variables
# Copy to .env.local (dev) or set in Vercel (prod). Never commit real secrets.

# --- Public site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Database (PostgreSQL) — required for the admin back-office & form persistence ---
# Neon / Supabase / Vercel Postgres. Use a POOLED connection string on Vercel.
# Without it, the public marketing site + calculator still work (fallback
# catalogue), but the application form and /admin do not.
DATABASE_URL="postgresql://user:password@host:5432/sandfinanz?schema=public"
# Direct (non-pooled) connection used ONLY for migrations. On Vercel/Neon set
# this to the non-pooling string. If you use a single direct connection you can
# leave it unset — the build falls back to DATABASE_URL for migrations.
# DIRECT_URL="postgresql://user:password@host:5432/sandfinanz?schema=public"

# --- Admin auth (required for /admin) ---
# Secret for signing session JWTs. Min 16 chars; use a long random value in prod.
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Seed (optional) — used by `npm run db:seed` to create the first super-admin ---
# SEED_ADMIN_EMAIL="admin@sand-finanz.example"
# SEED_ADMIN_PASSWORD="use-a-strong-password"

# --- Transactional e-mail (later batch) ---
# EMAIL_PROVIDER_API_KEY=""
# EMAIL_FROM="no-reply@example-sand-finanz.tld"

# --- Private file storage (later batch: secure uploads) ---
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""
# STORAGE_ENDPOINT=""
