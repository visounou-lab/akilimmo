{
  "name": "sand-finanz",
  "version": "0.1.0",
  "private": true,
  "description": "SAND FINANZ GRUPPE — multilingual financing site, credit calculator and application portal.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && sh -c 'if [ -n \"$DATABASE_URL\" ]; then DIRECT_URL=\"${DIRECT_URL:-$DATABASE_URL}\" prisma migrate deploy; else echo \"[build] DATABASE_URL not set — skipping migrations (public site works with fallback catalogue)\"; fi' && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.5.1",
    "bcryptjs": "^3.0.3",
    "bwip-js": "^4.11.2",
    "jose": "^6.2.3",
    "next": "15.5.15",
    "otplib": "^12.0.1",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.1.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  }
}
